NODE_ENV=development
PORT=4000

# Comma-separated allowed origins, e.g. http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Tip (macOS/Homebrew): your default Postgres role is usually your macOS username.
# You can often omit user/pass locally:
DATABASE_URL=postgres://localhost:5432/tourcheetah

JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Price ID from Stripe (Checkout Sessions)
STRIPE_PRICE_LIFETIME=price_replace_me
